---
const currentYear = new Date().getFullYear();
---

<footer class="bg-sodanca-dark text-white border-t border-white/5">
  <!-- Top Section -->
  <div class="mx-auto max-w-7xl px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
    
    <!-- Branding & Logo -->
    <div class="flex flex-col gap-6">
      <img 
        src="/assets/images/Logo-branca-3.png" 
        alt="Só Dança Logo" 
        class="h-12 w-auto object-contain self-start opacity-95"
      />
      <p class="text-sm text-gray-400 leading-relaxed max-w-sm">
        Só Dança est une marque internationale de référence pour les danseurs de tous niveaux, concevant des vêtements et chaussons de danse d'une qualité et d'un confort exceptionnels.
      </p>
    </div>

    <!-- Institutional Links -->
    <div class="flex flex-col gap-4">
      <h3 class="text-xs uppercase tracking-[0.2em] font-semibold text-sodanca-nude">
        Institutionnel
      </h3>
      <ul class="space-y-3 text-sm text-gray-400">
        <li>
          <a href="https://sodanca.pt" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
            Só Dança Europe (sodanca.pt)
          </a>
        </li>
        <li>
          <a href="https://sodanca.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
            Só Dança Global (sodanca.com)
          </a>
        </li>
        <li>
          <a href="/" class="hover:text-white transition-colors">
            Trouver un revendeur
          </a>
        </li>
      </ul>
    </div>

    <!-- Brand Social Networks -->
    <div class="flex flex-col gap-4">
      <h3 class="text-xs uppercase tracking-[0.2em] font-semibold text-sodanca-nude">
        Suivez la Marque
      </h3>
      <div class="flex items-center gap-4">
        <!-- Facebook -->
        <a 
          href="https://www.facebook.com/sodancaproductions/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="rounded-full bg-white/5 p-3 hover:bg-france-blue hover:text-white transition-all duration-300"
          aria-label="Facebook Só Dança"
        >
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z" />
          </svg>
        </a>
        <!-- Instagram -->
        <a 
          href="https://www.instagram.com/sodancaeurope/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="rounded-full bg-white/5 p-3 hover:bg-france-red hover:text-white transition-all duration-300"
          aria-label="Instagram Só Dança"
        >
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
          </svg>
        </a>
        <!-- YouTube -->
        <a 
          href="https://www.youtube.com/user/sodancaproductions" 
          target="_blank" 
          rel="noopener noreferrer"
          class="rounded-full bg-white/5 p-3 hover:bg-red-600 hover:text-white transition-all duration-300"
          aria-label="YouTube Só Dança"
        >
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Bottom Section -->
  <div class="border-t border-white/5 bg-black/20">
    <div class="mx-auto max-w-7xl px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>&copy; {currentYear} Só Dança France. Tous droits réservés.</p>
      <div class="flex items-center gap-6">
        <span class="text-sodanca-nude/60">Localisateur de Revendeurs Agréés</span>
        <a href="https://sodanca.pt" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Contact Europe</a>
      </div>
    </div>
  </div>
</footer>
