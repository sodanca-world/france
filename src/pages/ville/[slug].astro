---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import StoreCard from '../../components/StoreCard.astro';

export async function getStaticPaths() {
  const cidades = await getCollection('cidades');
  return cidades.map((cidade) => ({
    params: { slug: cidade.data.Slug },
    props: { cidade },
  }));
}

const { cidade } = Astro.props;

// Buscar lojas da cidade
const lojas = await getCollection('lojas');
const lojasNaCidade = lojas
  .filter((loja) => loja.data.Cidades.includes(cidade.data.Slug))
  .sort((a, b) => (a.data.Ordem || 99) - (b.data.Ordem || 99));

// Pegar redes sociais da primeira loja para alterar dinamicamente o sidebar de redes sociais
const primeiraLoja = lojasNaCidade[0]?.data;
const customFacebook = primeiraLoja?.Facebook || undefined;
const customInstagram = primeiraLoja?.Instagram || undefined;

const pageUrl = `https://france.sodanca.world/ville/${cidade.data.Slug}/`;
const locatorSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Boutiques de danse Só Dança à ${cidade.data.Nome}`,
  "url": pageUrl,
  "numberOfItems": lojasNaCidade.length,
  "itemListElement": lojasNaCidade.map((loja, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": loja.data.Nome,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": loja.data.Endereco || "",
        "addressLocality": cidade.data.Nome,
        "addressCountry": "FR"
      },
      "telephone": loja.data.Telefone || undefined,
      "url": `https://france.sodanca.world/cliente/${loja.data.Slug}/`
    }
  }))
};
---

<Layout 
  title={`Boutiques de Danse à ${cidade.data.Nome}`} 
  description={`Retrouvez la liste des revendeurs et boutiques de danse partenaires Só Dança à ${cidade.data.Nome}. Adresses, itinéraires, contacts.`}
  schema={locatorSchema}
  facebook={customFacebook}
  instagram={customInstagram}
>
  <div class="animate-fade-in max-w-4xl">
    
    <!-- Title Header -->
    <div class="mb-10 text-white select-none">
      <span class="text-xs uppercase tracking-[0.2em] font-bold text-sodanca-nude/80 block mb-1">
        Ville
      </span>
      <h1 class="font-sans text-3xl md:text-5xl font-extrabold tracking-tight">
        {cidade.data.Nome}
      </h1>
      <div class="h-1 w-12 bg-sodanca-nude mt-4"></div>
    </div>

    <!-- Stores List -->
    {lojasNaCidade.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {lojasNaCidade.map((loja) => (
          <StoreCard loja={loja.data} />
        ))}
      </div>
    ) : (
      <div class="py-12 px-6 text-center flex flex-col items-center justify-center border border-white/10 rounded-2xl bg-white/10 backdrop-blur-md text-white max-w-md">
        <svg class="h-10 w-10 text-sodanca-nude mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <h3 class="text-base font-bold mb-1">Aucune boutique enregistrée</h3>
        <p class="text-xs text-white/60 leading-relaxed">
          Nous n'avons actuellement aucun revendeur agréé répertorié à {cidade.data.Nome}.
        </p>
      </div>
    )}

  </div>
</Layout>
